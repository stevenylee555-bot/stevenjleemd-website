# Copy this file to .env.local and fill in real values for local development.
# In production, set these in the Vercel project's Environment Variables.

# GA4 measurement ID (looks like G-XXXXXXXXXX). Leave unset to ship without
# analytics: the site stays fully functional and the tracking code stays inert.
NEXT_PUBLIC_GA_ID=

# Contact "request a callback" form delivery (no backend needed).
# NEXT_PUBLIC_FORM_ENDPOINT: the POST URL.
#   - Formspree:  https://formspree.io/f/your-form-id
#   - Web3Forms:  https://api.web3forms.com/submit
# NEXT_PUBLIC_FORM_ACCESS_KEY: only for Web3Forms (its access key). Leave blank
# for Formspree. If the endpoint is unset, the form tells visitors to call.
NEXT_PUBLIC_FORM_ENDPOINT=
NEXT_PUBLIC_FORM_ACCESS_KEY=
